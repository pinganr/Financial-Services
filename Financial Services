  setTimeout(function(){btn.textContent='登 录';btn.classList.remove('loading');onLoginSuccess()},800);
}
function onLoginSuccess(){
  loggedIn=true;
  document.getElementById('loginForm').style.display='none';
  document.getElementById('welcomeCard').style.display='block';
  document.getElementById('navArea').innerHTML='<div class="nav-user"><span class="nav-user-dot"></span><span>'+USER_NAME+'</span></div>';
}
function doLogout(){
  loggedIn=false;
  document.getElementById('loginForm').style.display='block';
  document.getElementById('welcomeCard').style.display='none';
  document.getElementById('loginAcc').value='';
  document.getElementById('loginPwd').value='';
  document.getElementById('loginErr').classList.remove('show');
  document.getElementById('navArea').innerHTML='<button class="nav-login-btn" onclick="scrollToLogin()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> 登录</button>';
}
function scrollToLogin(){
  document.getElementById('loginAcc').focus();
  document.getElementById('heroCard').scrollIntoView({behavior:'smooth',block:'center'});
}

// CHECK LOGIN
function checkLogin(){
  if(!loggedIn){
    openM('warning','请先登录','您尚未登录系统',
      '<p>请先登录平安金融服务平台后，再进行相关操作。</p>',
      '<button class="m-btn sec" onclick="closeModalDirect()">取消</button><button class="m-btn pri" onclick="closeModalDirect();scrollToLogin()">去登录</button>');
    return false;
  }
  return true;
}
function handleService(type){
  if(!checkLogin())return;
  if(type==='plan')showResult();
  else if(type==='balance')showBalance();
  else if(type==='prepay')showPrepay();
  else if(type==='cert')showCertDownload();
}

// NAV PAGES
function navTo(page){
  if(!checkLogin())return;
  hideAllPages();
  if(page==='account')document.getElementById('accountPage').classList.add('show');
  else if(page==='invest')document.getElementById('investPage').classList.add('show');
  document.getElementById('homePage').classList.add('hide');
  window.scrollTo({top:0,behavior:'smooth'});
}

// MODAL
function openM(ic,tl,st,bd,ft){
  var icEl=document.getElementById('mIc');
  icEl.className='modal-ic '+ic;
  if(ic==='info')icEl.innerHTML='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>';
  else if(ic==='warning')icEl.innerHTML='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
  else if(ic==='error')icEl.innerHTML='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
  document.getElementById('mTl').textContent=tl;
  document.getElementById('mSt').textContent=st;
  document.getElementById('mBd').innerHTML=bd;
  document.getElementById('mFt').innerHTML=ft;
  document.getElementById('modalOv').classList.add('show');
}
function closeModal(e){if(e&&e.target!==document.getElementById('modalOv'))return;document.getElementById('modalOv').classList.remove('show')}
function closeModalDirect(){document.getElementById('modalOv').classList.remove('show')}

// SECURITY SETTINGS
function showChangePwd(){
  openM('info','修改密码','密码修改功能',
    '<p>为保障账户安全，请通过平安口袋银行APP进行密码修改操作。</p>',
    '<button class="m-btn pri" onclick="closeModalDirect()">我知道了</button>');
}
function showPayPwd(){
  openM('info','支付密码','支付密码管理',
    '<p>支付密码修改需通过平安口袋银行APP完成身份验证后操作。</p>',
    '<button class="m-btn pri" onclick="closeModalDirect()">我知道了</button>');
}
function showChangePhone(){
  openM('info','更换手机号','手机号变更',
    '<p>更换绑定手机号需携带身份证至网点办理，或通过平安口袋银行APP视频核身办理。</p>',
    '<button class="m-btn pri" onclick="closeModalDirect()">我知道了</button>');
}

// BALANCE
function showBalance(){
  var now=new Date();var rem=243900.00,paidP=0,paidT=0;
  for(var i=0;i<D.length;i++){var rd=pd(D[i][1]);if(now>=rd){paidP=D[i][0];rem=D[i][3];paidT=D[i][0]*MONTHLY}}
  if(now<LOAN_START){rem=243900.00;paidP=0;paidT=0}
  var qd=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0');
  var prPaid=(243900.00-rem).toFixed(2),pct=((paidP/TOTAL_P)*100).toFixed(1),left=TOTAL_P-paidP;
  openM('info','贷款余额查询','合同编号：LN2026032600156',
    '<div class="modal-hl"><div class="modal-hl-r"><span class="modal-hl-l">查询日期</span><span class="modal-hl-v">'+qd+'</span></div><div class="modal-hl-r"><span class="modal-hl-l">剩余本金</span><span class="modal-hl-v big">¥'+fm(rem)+'</span></div><div class="modal-hl-r"><span class="modal-hl-l">已还期数</span><span class="modal-hl-v">'+paidP+' / '+TOTAL_P+' 期</span></div><div class="modal-hl-r"><span class="modal-hl-l">剩余期数</span><span class="modal-hl-v">'+left+' 期</span></div><div class="modal-hl-r"><span class="modal-hl-l">已还总额</span><span class="modal-hl-v">¥'+fm(paidT)+'</span></div><div class="modal-hl-r"><span class="modal-hl-l">其中已还本金</span><span class="modal-hl-v">¥'+fm(parseFloat(prPaid))+'</span></div><div class="modal-hl-r"><span class="modal-hl-l">还款进度</span><span class="modal-hl-v">'+pct+'%</span></div></div>',
    '<button class="m-btn sec" onclick="closeModalDirect()">关闭</button><button class="m-btn pri" onclick="closeModalDirect();showResult()">查看还款计划</button>');
}

// PREPAY
function showPrepay(){
  var now=new Date();var oy=new Date(LOAN_START);oy.setFullYear(oy.getFullYear()+1);
  if(now<oy){
    var ed=oy.getFullYear()+'-'+String(oy.getMonth()+1).padStart(2,'0')+'-'+String(oy.getDate()).padStart(2,'0');
    openM('warning','提前还款申请','暂不满足提前还款条件',
      '<p>尊敬的客户，您的贷款合同（LN2026032600156）当前<strong>贷款发放不足一年</strong>，根据贷款合同相关条款约定，暂不支持提前还款申请。</p><div class="modal-hl"><div class="modal-hl-r"><span class="modal-hl-l">贷款发放日</span><span class="modal-hl-v">2026-04-26</span></div><div class="modal-hl-r"><span class="modal-hl-l">最早可申请日</span><span class="modal-hl-v">'+ed+'</span></div><div class="modal-hl-r"><span class="modal-hl-l">合同编号</span><span class="modal-hl-v">LN2026032600156</span></div></div><p>请您在贷款发放满一年后重新提交提前还款申请。如有疑问，请联系客服热线 95511。</p>',
      '<button class="m-btn sec" onclick="closeModalDirect()">联系客服</button><button class="m-btn pri" onclick="closeModalDirect()">我知道了</button>');
  }
}

// CERT
function showCertDownload(){
  openM('error','还款凭证下载','贷款合同未结清',
    '<p>尊敬的客户，您的贷款合同（LN2026032600156）当前<strong>尚未结清</strong>，暂无法下载还款结清证明。</p><div class="modal-hl"><div class="modal-hl-r"><span class="modal-hl-l">合同编号</span><span class="modal-hl-v">LN2026032600156</span></div><div class="modal-hl-r"><span class="modal-hl-l">合同状态</span><span class="modal-hl-v" style="color:var(--red)">还款中 · 未结清</span></div><div class="modal-hl-r"><span class="modal-hl-l">到期日期</span><span class="modal-hl-v">2030-03-26</span></div></div><p>还款结清证明需在贷款全部还清后方可生成下载。</p>',
    '<button class="m-btn sec" onclick="closeModalDirect()">关闭</button><button class="m-btn pri" onclick="closeModalDirect();showResult()">查看还款计划</button>');
}

// RESULT
function showResult(){
  hideAllPages();document.getElementById('resultPage').classList.add('show');
  document.getElementById('homePage').classList.add('hide');
  renderTbl('all');window.scrollTo({top:0,behavior:'smooth'});
  setTimeout(function(){document.getElementById('progFill').style.width='100%'},400);
}
function goHome(){
  hideAllPages();
  document.getElementById('homePage').classList.remove('hide');
  window.scrollTo({top:0,behavior:'smooth'});
}
function hideAllPages(){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('show')});
}
function renderTbl(f){
  var tb=document.getElementById('tblBody');tb.innerHTML='';var ly=null;
  D.forEach(function(r){var y=gy(r[1]);if(f!=='all'&&y!==f)return;if(y!==ly){var tr=document.createElement('tr');tr.className='yr-div';tr.innerHTML='<td colspan="4">'+y+' 年</td>';tb.appendChild(tr);ly=y}var tr=document.createElement('tr');var c=r[3]===0?'p-zero':'p-rem';tr.innerHTML='<td><span class="p-num">'+String(r[0]).padStart(2,'0')+' / 48</span></td><td><span class="p-date">'+fd(r[1])+'</span></td><td><span class="p-amt">'+fm(r[2])+'</span></td><td><span class="'+c+'">'+fm(r[3])+'</span></td>';tb.appendChild(tr)});
  var cnt=f==='all'?48:D.filter(function(r){return gy(r[1])===f}).length;
  document.getElementById('progFill').style.width=(f==='all'?100:cnt/48*100)+'%';
  document.getElementById('progTxt').textContent=f==='all'?'48 / 48 期 · 全部':cnt+' 期 · '+f+' 年';
}
function filterY(y,b){document.querySelectorAll('.f-btn').forEach(function(x){x.classList.remove('active')});b.classList.add('active');renderTbl(y)}
</script>

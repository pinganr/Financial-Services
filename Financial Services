<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>平安金融服务平台</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#faf8f5;--white:#fff;--surface:#fff;--surface-alt:#fdf9f3;
  --border:#ede5d8;--border-light:#f3eee6;
  --primary:#d97706;--primary-light:#fef3c7;--primary-dark:#b45309;--primary-glow:rgba(217,119,6,.08);
  --g-start:#f59e0b;--g-mid:#ea580c;--accent:#ea580c;
  --green:#16a34a;--green-l:#dcfce7;--red:#dc2626;--red-l:#fee2e2;
  --blue:#2563eb;--blue-l:#dbeafe;--purple:#7c3aed;--purple-l:#f3f0ff;
  --text1:#1c1917;--text2:#78716c;--text3:#a8a29e;
  --shadow-s:0 1px 3px rgba(0,0,0,.04);--shadow-m:0 4px 16px rgba(0,0,0,.06);--shadow-l:0 12px 40px rgba(0,0,0,.08);
  --r:12px;--rs:8px;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text1);font-family:'Noto Sans SC',-apple-system,sans-serif;min-height:100vh;line-height:1.6}

/* NAV */
.top-bar{background:linear-gradient(135deg,var(--g-start) 0%,var(--g-mid) 60%,#c2410c);color:#fff;position:relative;overflow:hidden}
.top-bar::before{content:'';position:absolute;top:-50%;right:-10%;width:400px;height:400px;background:radial-gradient(circle,rgba(255,255,255,.08),transparent 70%);pointer-events:none}
.top-nav{max-width:1200px;margin:0 auto;padding:14px 32px;display:flex;justify-content:space-between;align-items:center;position:relative;z-index:2}
.logo{display:flex;align-items:center;gap:12px}
.logo-icon{width:42px;height:42px;background:rgba(255,255,255,.2);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.15)}
.logo-text{font-size:1.2rem;font-weight:600;letter-spacing:-.01em}
.logo-sub{font-size:.72rem;opacity:.75;font-weight:300;letter-spacing:.02em}
.nav-links{display:flex;gap:28px;align-items:center}
.nav-links a{color:rgba(255,255,255,.8);text-decoration:none;font-size:.88rem;font-weight:400;transition:color .2s;position:relative;cursor:pointer}
.nav-links a:hover{color:#fff}
.nav-links a.active{color:#fff;font-weight:500}
.nav-links a.active::after{content:'';position:absolute;bottom:-6px;left:0;right:0;height:2px;background:rgba(255,255,255,.8);border-radius:1px}
.nav-user{display:flex;align-items:center;gap:8px;padding:6px 14px;background:rgba(255,255,255,.12);border-radius:20px;font-size:.82rem;cursor:default;border:1px solid rgba(255,255,255,.1)}
.nav-user-dot{width:6px;height:6px;background:#4ade80;border-radius:50%}
.nav-login-btn{display:flex;align-items:center;gap:6px;padding:6px 16px;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.3);border-radius:20px;font-size:.82rem;color:#fff;font-family:'Noto Sans SC',sans-serif;cursor:pointer;transition:all .2s}
.nav-login-btn:hover{background:rgba(255,255,255,.3)}

/* HERO */
.hero{background:linear-gradient(135deg,var(--g-start),var(--g-mid) 60%,#c2410c);color:#fff;position:relative;overflow:hidden}
.hero::after{content:'';position:absolute;bottom:-40%;left:5%;width:350px;height:350px;background:radial-gradient(circle,rgba(255,255,255,.05),transparent 70%);pointer-events:none}
.hero-inner{max-width:1200px;margin:0 auto;padding:44px 32px 56px;display:flex;justify-content:space-between;align-items:center;gap:40px;position:relative;z-index:2}
.hero-text{flex:1;animation:fadeUp .6s ease forwards}
.hero-badge{display:inline-block;background:rgba(255,255,255,.15);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.2);padding:4px 14px;border-radius:20px;font-size:.76rem;font-weight:500;letter-spacing:.04em;margin-bottom:16px}
.hero-text h1{font-size:2rem;font-weight:700;letter-spacing:-.02em;margin-bottom:10px;line-height:1.3}
.hero-text p{font-size:.95rem;opacity:.85;font-weight:300;max-width:460px;line-height:1.7}
.hero-stats{display:flex;gap:32px;margin-top:28px}
.hero-stat{text-align:center}
.hero-stat-val{font-family:'DM Mono',monospace;font-size:1.6rem;font-weight:500}
.hero-stat-label{font-size:.75rem;opacity:.7;margin-top:2px}
.hero-card{width:400px;flex-shrink:0;animation:fadeUp .6s ease .2s forwards;opacity:0}

/* CARD */
.q-card{background:var(--white);border-radius:16px;box-shadow:var(--shadow-l);overflow:hidden;border:1px solid rgba(255,255,255,.1)}
.q-card-hd{background:linear-gradient(135deg,#fffbeb,#fef3c7);padding:20px 24px;border-bottom:1px solid var(--border-light);display:flex;align-items:center;gap:10px}
.q-card-ic{width:36px;height:36px;background:var(--primary-light);border-radius:10px;display:flex;align-items:center;justify-content:center;color:var(--primary)}
.q-card-tl{font-size:1rem;font-weight:600;color:var(--text1)}
.q-card-st{font-size:.76rem;color:var(--text3);font-weight:400}
.q-card-bd{padding:24px}
.fg{margin-bottom:16px}
.fl{display:block;font-size:.82rem;font-weight:500;color:var(--text2);margin-bottom:6px}
.fi{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--rs);font-size:.9rem;font-family:'DM Mono',monospace;color:var(--text1);background:var(--surface-alt);transition:all .2s;outline:none}
.fi:focus{border-color:var(--primary);background:var(--white);box-shadow:0 0 0 3px var(--primary-glow)}
.fi::placeholder{color:var(--text3);font-family:'Noto Sans SC',sans-serif}
.f-err{font-size:.76rem;color:var(--red);margin-top:6px;display:none;align-items:center;gap:4px}
.f-err.show{display:flex}
.err-ic{width:14px;height:14px;border-radius:50%;background:var(--red-l);color:var(--red);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0}
.q-btn{width:100%;padding:12px;background:linear-gradient(135deg,var(--g-start),var(--accent));color:#fff;border:none;border-radius:var(--rs);font-size:.92rem;font-weight:600;font-family:'Noto Sans SC',sans-serif;cursor:pointer;transition:all .25s;margin-top:8px;position:relative;overflow:hidden}
.q-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(217,119,6,.35)}
.q-btn:active{transform:translateY(0)}
.q-btn.loading{pointer-events:none;opacity:.8}

/* WELCOME CARD */
.wc{padding:24px}
.wc-hd{display:flex;align-items:center;gap:14px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border-light)}
.wc-avatar{width:48px;height:48px;background:linear-gradient(135deg,var(--g-start),var(--accent));border-radius:14px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:18px;font-weight:700}
.wc-name{font-size:1.1rem;font-weight:700;color:var(--text1)}
.wc-id{font-size:.74rem;color:var(--text3);font-family:'DM Mono',monospace;margin-top:2px}
.wc-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.wc-item{background:var(--surface-alt);border:1px solid var(--border-light);border-radius:var(--rs);padding:14px;text-align:center}
.wc-item-label{font-size:.72rem;color:var(--text3);margin-bottom:4px}
.wc-item-val{font-family:'DM Mono',monospace;font-size:1.1rem;font-weight:500;color:var(--text1)}
.wc-actions{display:flex;gap:10px}
.wc-act{flex:1;padding:10px;border-radius:var(--rs);font-size:.82rem;font-weight:500;font-family:'Noto Sans SC',sans-serif;cursor:pointer;transition:all .2s;text-align:center}
.wc-act-primary{background:linear-gradient(135deg,var(--g-start),var(--accent));color:#fff;border:none}
.wc-act-primary:hover{box-shadow:0 4px 14px rgba(217,119,6,.3);transform:translateY(-1px)}
.wc-act-secondary{background:var(--surface-alt);border:1.5px solid var(--border);color:var(--text2)}
.wc-act-secondary:hover{border-color:var(--primary);color:var(--primary)}
.wc-logout{display:block;width:100%;margin-top:12px;padding:8px;background:transparent;border:1.5px solid var(--border);border-radius:var(--rs);font-size:.8rem;color:var(--text3);font-family:'Noto Sans SC',sans-serif;cursor:pointer;transition:all .2s}
.wc-logout:hover{border-color:var(--red);color:var(--red)}

/* SERVICES */
.services{max-width:1200px;margin:-30px auto 0;padding:0 32px;position:relative;z-index:10}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.s-card{background:var(--white);border-radius:var(--r);padding:24px 20px;text-align:center;box-shadow:var(--shadow-s);border:1px solid var(--border-light);cursor:pointer;transition:all .3s;position:relative;overflow:hidden}
.s-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-m);border-color:var(--primary)}
.s-card.hot{border-color:var(--primary);background:linear-gradient(180deg,var(--primary-light),var(--white));box-shadow:0 4px 16px rgba(217,119,6,.1)}
.s-card.hot::after{content:'热门';position:absolute;top:10px;right:-24px;background:linear-gradient(135deg,var(--g-start),var(--accent));color:#fff;font-size:.62rem;padding:2px 28px;transform:rotate(45deg);font-weight:500}
.s-ic{width:52px;height:52px;margin:0 auto 14px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;transition:transform .3s}
.s-card:hover .s-ic{transform:scale(1.08)}
.s-ic.orange{background:#fff7ed;color:var(--accent)}
.s-ic.green{background:var(--green-l);color:var(--green)}
.s-ic.amber{background:var(--primary-light);color:var(--primary)}
.s-ic.red{background:var(--red-l);color:var(--red)}
.s-name{font-size:.9rem;font-weight:600;color:var(--text1);margin-bottom:4px}
.s-desc{font-size:.74rem;color:var(--text3)}

/* RESULT PAGE */
.page{display:none;max-width:1200px;margin:0 auto;padding:32px 32px 80px;animation:fadeUp .5s ease forwards}
.page.show{display:block}
.home.hide{display:none}
.breadcrumb{display:flex;align-items:center;gap:8px;font-size:.82rem;color:var(--text3);margin-bottom:24px}
.breadcrumb a{color:var(--primary);text-decoration:none;cursor:pointer}
.breadcrumb a:hover{text-decoration:underline}
.bc-sep{color:var(--border)}
.pg-hd{background:var(--white);border-radius:var(--r);padding:28px 32px;box-shadow:var(--shadow-s);border:1px solid var(--border-light);margin-bottom:24px;display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap}
.pg-info{flex:1}
.pg-title{font-size:1.3rem;font-weight:700;color:var(--text1);margin-bottom:4px;letter-spacing:-.01em}
.pg-sub{font-size:.86rem;color:var(--text2);font-weight:400}
.pg-badge{display:inline-flex;align-items:center;gap:6px;background:var(--green-l);color:var(--green);padding:6px 14px;border-radius:20px;font-size:.8rem;font-weight:500}
.pg-badge-dot{width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.back-btn{padding:8px 20px;background:var(--surface-alt);border:1.5px solid var(--border);border-radius:var(--rs);font-size:.84rem;font-weight:500;color:var(--text2);font-family:'Noto Sans SC',sans-serif;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;white-space:nowrap}
.back-btn:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-glow)}

/* SUMMARY */
.summary{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
.sum-card{background:var(--white);border:1px solid var(--border-light);border-radius:var(--r);padding:22px 20px;position:relative;overflow:hidden;box-shadow:var(--shadow-s);animation:fadeUp .5s ease forwards;opacity:0}
.sum-card:nth-child(1){animation-delay:.05s}.sum-card:nth-child(2){animation-delay:.1s}.sum-card:nth-child(3){animation-delay:.15s}.sum-card:nth-child(4){animation-delay:.2s}
.sum-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:0 0 2px 2px}
.sum-card:nth-child(1)::before{background:linear-gradient(90deg,var(--g-start),var(--accent))}
.sum-card:nth-child(2)::before{background:linear-gradient(90deg,#fbbf24,#f59e0b)}
.sum-card:nth-child(3)::before{background:linear-gradient(90deg,#fb923c,#ea580c)}
.sum-card:nth-child(4)::before{background:linear-gradient(90deg,var(--green),#4ade80)}
.sum-ic{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;margin-bottom:12px}
.sum-ic.orange{background:#fff7ed;color:var(--accent)}
.sum-ic.amber{background:var(--primary-light);color:var(--primary)}
.sum-ic.burnt{background:#ffedd5;color:#c2410c}
.sum-ic.green{background:var(--green-l);color:var(--green)}
.sum-label{font-size:.76rem;color:var(--text3);font-weight:500;margin-bottom:6px}
.sum-val{font-family:'DM Mono',monospace;font-size:1.5rem;font-weight:500;color:var(--text1);line-height:1.2}
.sum-sub{font-size:.72rem;color:var(--text2);margin-top:6px}

/* TABLE */
.tbl-wrap{background:var(--white);border:1px solid var(--border-light);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow-s);animation:fadeUp .5s ease .25s forwards;opacity:0}
.tbl-hd{display:flex;justify-content:space-between;align-items:center;padding:18px 24px;border-bottom:1px solid var(--border-light);flex-wrap:wrap;gap:12px}
.tbl-tl{font-size:1rem;font-weight:600;color:var(--text1);display:flex;align-items:center;gap:8px}
.tbl-dot{width:8px;height:8px;background:var(--primary);border-radius:2px}
.tbl-flt{display:flex;gap:6px;flex-wrap:wrap}
.f-btn{background:var(--surface-alt);border:1.5px solid var(--border);color:var(--text2);padding:5px 14px;border-radius:6px;font-size:.78rem;font-family:'Noto Sans SC',sans-serif;cursor:pointer;transition:all .2s;font-weight:500}
.f-btn:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-glow)}
.f-btn.active{background:linear-gradient(135deg,var(--g-start),var(--accent));border-color:transparent;color:#fff}
.tbl-scroll{overflow-x:auto;max-height:65vh;overflow-y:auto}
.tbl-scroll::-webkit-scrollbar{width:5px;height:5px}
.tbl-scroll::-webkit-scrollbar-track{background:var(--surface-alt)}
.tbl-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
table{width:100%;border-collapse:collapse;font-size:.86rem}
thead{position:sticky;top:0;z-index:10}
th{background:#fdf7ee;padding:12px 20px;text-align:left;font-weight:600;font-size:.76rem;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--border-light);white-space:nowrap}
th:nth-child(n+3){text-align:right}
td{padding:12px 20px;border-bottom:1px solid var(--border-light);white-space:nowrap;transition:background .15s}
td:nth-child(n+3){text-align:right}
tr:hover td{background:rgba(217,119,6,.03)}
.yr-div td{background:#fffbeb!important;padding:8px 20px;font-size:.78rem;color:var(--primary);font-weight:600;letter-spacing:.04em;border-bottom:1px solid rgba(217,119,6,.1)}
.p-num{color:var(--text2);font-family:'DM Mono',monospace;font-size:.84rem}
.p-amt{color:var(--primary);font-weight:500;font-family:'DM Mono',monospace;font-size:.84rem}
.p-rem{color:var(--accent);font-family:'DM Mono',monospace;font-size:.84rem}
.p-zero{color:var(--green);font-weight:600;font-family:'DM Mono',monospace;font-size:.84rem}
.p-date{color:var(--text2);font-size:.82rem}
.prog-row{display:flex;align-items:center;gap:14px;padding:14px 24px;border-top:1px solid var(--border-light);background:#fdf7ee}
.prog-lb{font-size:.76rem;color:var(--text3);white-space:nowrap;font-weight:600;letter-spacing:.04em}
.prog-bar{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--g-start),var(--accent));border-radius:3px;width:0%;transition:width 1.5s ease}
.prog-txt{font-family:'DM Mono',monospace;font-size:.8rem;color:var(--primary);font-weight:500;white-space:nowrap}

/* MODAL */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(28,25,23,.45);backdrop-filter:blur(4px);z-index:1000;justify-content:center;align-items:center;animation:fadeIn .2s ease}
.modal-ov.show{display:flex}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal{background:var(--white);border-radius:16px;width:520px;max-width:92vw;box-shadow:0 20px 60px rgba(0,0,0,.15);animation:modalSlide .3s ease;overflow:hidden;max-height:90vh;overflow-y:auto}
@keyframes modalSlide{from{opacity:0;transform:translateY(20px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.modal-hd{padding:24px 28px 0;display:flex;align-items:flex-start;gap:14px}
.modal-ic{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.modal-ic.info{background:var(--blue-l);color:var(--blue)}
.modal-ic.warning{background:var(--primary-light);color:var(--primary)}
.modal-ic.error{background:var(--red-l);color:var(--red)}
.modal-tl{font-size:1.1rem;font-weight:700;color:var(--text1);margin-bottom:4px}
.modal-st{font-size:.82rem;color:var(--text3)}
.modal-bd{padding:20px 28px}
.modal-bd p{font-size:.88rem;color:var(--text2);line-height:1.8}
.modal-hl{background:var(--surface-alt);border:1px solid var(--border-light);border-radius:var(--rs);padding:16px 18px;margin:14px 0}
.modal-hl-r{display:flex;justify-content:space-between;align-items:center;padding:6px 0;font-size:.84rem}
.modal-hl-r:not(:last-child){border-bottom:1px solid var(--border-light)}
.modal-hl-l{color:var(--text3)}
.modal-hl-v{font-family:'DM Mono',monospace;font-weight:500;color:var(--text1)}
.modal-hl-v.big{font-size:1.3rem;color:var(--primary)}
.modal-ft{padding:16px 28px 24px;display:flex;justify-content:flex-end;gap:10px}
.m-btn{padding:9px 24px;border-radius:var(--rs);font-size:.86rem;font-weight:500;font-family:'Noto Sans SC',sans-serif;cursor:pointer;transition:all .2s;border:none}
.m-btn.pri{background:linear-gradient(135deg,var(--g-start),var(--accent));color:#fff}
.m-btn.pri:hover{box-shadow:0 4px 14px rgba(217,119,6,.3);transform:translateY(-1px)}
.m-btn.sec{background:var(--surface-alt);border:1.5px solid var(--border);color:var(--text2)}
.m-btn.sec:hover{border-color:var(--primary);color:var(--primary)}

/* INFO PAGE SECTIONS */
.info-section{background:var(--white);border:1px solid var(--border-light);border-radius:var(--r);padding:28px 32px;margin-bottom:20px;box-shadow:var(--shadow-s)}
.info-section h3{font-size:1.05rem;font-weight:700;color:var(--text1);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.info-section h3 .dot{width:8px;height:8px;background:var(--primary);border-radius:2px}
.info-row{display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border-light);font-size:.88rem}
.info-row:last-child{border-bottom:none}
.info-label{color:var(--text3)}
.info-val{color:var(--text1);font-weight:500}
.info-link{color:var(--primary);text-decoration:none;cursor:pointer;transition:color .2s}
.info-link:hover{color:var(--primary-dark);text-decoration:underline}
.info-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
.info-card{background:var(--surface-alt);border:1px solid var(--border-light);border-radius:var(--rs);padding:18px;text-align:center}
.info-card-ic{font-size:24px;margin-bottom:8px}
.info-card-tl{font-size:.84rem;font-weight:600;color:var(--text1);margin-bottom:4px}
.info-card-desc{font-size:.72rem;color:var(--text3)}
.invest-chart{background:var(--surface-alt);border:1px solid var(--border-light);border-radius:var(--rs);padding:24px;margin-bottom:16px;text-align:center}
.invest-bars{display:flex;align-items:flex-end;justify-content:center;gap:12px;height:120px;margin-bottom:12px}
.invest-bar{width:36px;border-radius:4px 4px 0 0;transition:height .5s ease;background:var(--border)}
.invest-bar.b1{height:4px;background:var(--primary-light);border:1px solid var(--primary)}
.invest-bar.b2{height:4px;background:var(--primary-light);border:1px solid var(--primary)}
.invest-bar.b3{height:4px;background:var(--primary);border:1px solid var(--primary-dark)}
.invest-bar.b4{height:4px;background:var(--accent);border:1px solid #c2410c}
.invest-legend{display:flex;justify-content:center;gap:20px;font-size:.76rem;color:var(--text3)}
.invest-legend span{display:flex;align-items:center;gap:4px}
.invest-legend-dot{width:8px;height:8px;border-radius:2px}

footer{max-width:1200px;margin:0 auto;padding:24px 32px;text-align:center;font-size:.76rem;color:var(--text3);border-top:1px solid var(--border-light);margin-top:40px}
footer a{color:var(--text2);text-decoration:none}footer a:hover{color:var(--primary)}
